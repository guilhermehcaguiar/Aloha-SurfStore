# --- DEPENDÊNCIAS ---
# Nunca suba a pasta node_modules (ela é recriada com 'npm install')
node_modules/

# --- EXPO & BUILDS ---
# Pastas geradas pelo Expo durante o desenvolvimento e build
.expo/
dist/
web-build/

# --- LOGS ---
# Arquivos de erro gerados pelo instalador de pacotes
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- SISTEMA ---
# Arquivos que o Windows e o Mac criam sozinhos nas pastas
.DS_Store
Thumbs.db

# --- CONFIGURAÇÕES DE IDE ---
# Configurações pessoais do seu VS Code
.vscode/
.history/